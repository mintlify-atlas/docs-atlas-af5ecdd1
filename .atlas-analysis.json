  "keyFeatures": [
    "Bilingual content in Spanish and Nahuatl",
    "Audio narration for oral storytelling tradition",
    "Geolocation and interactive map of stories",
    "User authentication and story contributions",
    "Favorites and offline access with Room database",
    "Nahuatl-Spanish dictionary",
    "Firebase backend for real-time sync",
    "Material Design 3 with custom theme"
  ],
  "publicApiSurface": [
    "StoryRepository.getAllStories()",
    "StoryRepository.getStoryById(id)",
    "StoryRepository.searchStories(query)",
    "StoryRepository.addStory(story)",
    "StoryRepository.addToFavorites(storyId)",
    "AuthRepository.signIn(email, password)",
    "AuthRepository.signUp(email, password)",
    "FirestoreRepository.getAllStoriesFlow()",
    "StoryDao.getAllStories()",
    "StoryDao.getFavoriteStories()",
    "Screen.Discover.route",
    "Screen.StoryList.route",
    "Screen.StoryMap.route",
    "Screen.AddStory.route",
    "NavGraph composable"
  ]
